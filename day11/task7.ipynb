   "source": [
    "### np二维数组转置练习，轴滚动练习"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "initial_id",
   "metadata": {
    "collapsed": true
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "原数组：\n",
      "[[1 2 3]\n",
      " [4 5 6]]\n",
      "转置后的数组：\n",
      "[[1 4]\n",
      " [2 5]\n",
      " [3 6]]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "# 创建一个二维数组\n",
    "arr = np.array([[1, 2, 3], [4, 5, 6]])\n",
    "\n",
    "print(\"原数组：\")\n",
    "print(arr)\n",
    "\n",
    "# 转置数组\n",
    "arr_T = arr.T\n",
    "\n",
    "print(\"转置后的数组：\")\n",
    "print(arr_T)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "da9d09f5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "轴滚动后的数组：\n",
      "[[4 5 6]\n",
      " [1 2 3]]\n"
     ]
    }
   ],
   "source": [
    "# 轴滚动练习\n",
    "arr_rolled = np.roll(arr, 1, axis=0)\n",
    "print(\"轴滚动后的数组：\")\n",
    "print(arr_rolled)"
   ]
  },
